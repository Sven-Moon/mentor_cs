@page
@model IndexModel
@{
    ViewData["Title"] = "Mentorships";

    string StatusBadgeClass(string status) => status.ToLower() switch
    {
        "active"    => "bg-success",
        "completed" => "bg-secondary",
        "cancelled" => "bg-danger",
        "paused"    => "bg-warning text-dark",
        _           => "bg-info text-dark"
    };

    // Active mentorships first, then by start date descending
    var ordered = Model.Mentorships
        .OrderByDescending(m => m.Status.Equals("Active", StringComparison.OrdinalIgnoreCase))
        .ThenByDescending(m => m.StartDate)
        .ToList();
}

<!-- Page header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Mentorships</h1>
    @if (User.IsInRole("Admin"))
    {
        <button type="button"
                class="btn btn-primary d-flex align-items-center gap-2"
                data-bs-toggle="modal"
                data-bs-target="#createMentorshipModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 class="bi bi-plus-lg" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
            </svg>
            New Mentorship
        </button>
    }
</div>

<!-- Alerts -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Mentorship cards -->
@if (!ordered.Any())
{
    <div class="text-center py-5 text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
             class="bi bi-people mb-3 opacity-50" viewBox="0 0 16 16">
            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.966.544-2.165 1.81-3.043A4.3 4.3 0 0 1 4.92 10M1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4" />
        </svg>
        <p class="fs-5">No mentorships yet.</p>
        @if (User.IsInRole("Admin"))
        {
            <button type="button" class="btn btn-primary"
                    data-bs-toggle="modal" data-bs-target="#createMentorshipModal">
                Create the first one
            </button>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var ms in ordered)
        {
            var isActive = ms.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);
            var mentorName = ms.Mentor?.UserName ?? ms.MentorId;
            var menteeName = ms.Mentee?.UserName ?? ms.MenteeId;

            <div class="col">
                <div class="card h-100 shadow-sm @(isActive ? "border-success" : "")">
                    <div class="card-header d-flex justify-content-between align-items-start">
                        <div>
                            <span class="fw-semibold">@mentorName</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                 class="bi bi-arrow-right mx-1 text-muted" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8" />
                            </svg>
                            <span class="fw-semibold">@menteeName</span>
                        </div>
                        <span class="badge @StatusBadgeClass(ms.Status) ms-2">@ms.Status</span>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted mb-3">@ms.Scope</p>
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted fw-normal">Start</dt>
                            <dd class="col-7">@ms.StartDate.ToString("MMM d, yyyy")</dd>

                            <dt class="col-5 text-muted fw-normal">End</dt>
                            <dd class="col-7">@ms.EndDate.ToString("MMM d, yyyy")</dd>

                            @if (ms.LastInteractionDate.HasValue)
                            {
                                <dt class="col-5 text-muted fw-normal">Last contact</dt>
                                <dd class="col-7">@ms.LastInteractionDate.Value.ToString("MMM d, yyyy")</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- ---------------------------------------------------------------- -->
<!-- Create Mentorship Modal (admin only)                              -->
<!-- ---------------------------------------------------------------- -->
@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="createMentorshipModal" tabindex="-1"
         aria-labelledby="createMentorshipModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createMentorshipModalLabel">New Mentorship</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" asp-page-handler="Create">
                    <div class="modal-body">

                        <div class="mb-3">
                            <label asp-for="NewMentorId" class="form-label">Mentor</label>
                            <select asp-for="NewMentorId" class="form-select" required>
                                <option value="">— select mentor —</option>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u.Id">@u.Email</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewMenteeId" class="form-label">Mentee</label>
                            <select asp-for="NewMenteeId" class="form-select" required>
                                <option value="">— select mentee —</option>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u.Id">@u.Email</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewScope" class="form-label">Scope</label>
                            <input asp-for="NewScope" class="form-control"
                                   placeholder="e.g. Career guidance, Technical skills" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewStatus" class="form-label">Status</label>
                            <select asp-for="NewStatus" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Paused">Paused</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label asp-for="NewStartDate" class="form-label">Start date</label>
                                <input asp-for="NewStartDate" type="date" class="form-control" required />
                            </div>
                            <div class="col-6">
                                <label asp-for="NewEndDate" class="form-label">End date</label>
                                <input asp-for="NewEndDate" type="date" class="form-control" required />
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Re-open modal on validation error -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <script>
            bootstrap.Modal.getOrCreateInstance(document.getElementById('createMentorshipModal')).show();
        </script>
    }
}

@section Scripts {
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
}
