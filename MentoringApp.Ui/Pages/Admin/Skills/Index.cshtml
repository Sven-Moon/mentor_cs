@page
@model IndexModel
@{
	ViewData["Title"] = "Skill Moderation";
}

<div class="d-flex align-items-center mb-4">
	<h1 class="mb-0">Skill Moderation</h1>
	@if (Model.PendingSkills.Any())
	{
		<span class="badge bg-warning text-dark ms-3 fs-6">@Model.PendingSkills.Count pending</span>
	}
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
	<div class="alert alert-success alert-dismissible fade show" role="alert">
		@Model.SuccessMessage
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-danger alert-dismissible fade show" role="alert">
		@Model.ErrorMessage
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}

@if (!Model.PendingSkills.Any())
{  // TODO: turn into component (circled checkmark)
	 <div class="text-center py-5 text-muted">
	 	<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
	 			 class="bi bi-check-circle mb-3 d-block mx-auto" viewBox="0 0 16 16">
	 		<path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
	 		<path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z" />
	 	</svg>
	 	<p class="fs-5">No pending skills to review.</p>
	 </div>
}
else
{
	<div class="d-flex flex-column gap-3">
		@foreach (var skill in Model.PendingSkills)
		{
			<div class="card" id="skill-@skill.Id">
				<div class="card-header d-flex align-items-start gap-3 flex-wrap">
					<div class="flex-grow-1">
						<h5 class="mb-0">@skill.Name</h5>
						@if (skill.Categories.Any())
						{
							<div class="mt-1">
								@foreach (var cat in skill.Categories)
								{
									<span class="badge bg-light text-dark border me-1">@cat</span>
								}
							</div>
						}
					</div>
					<div class="d-flex gap-2 flex-wrap">
						<form method="post" asp-page-handler="ApproveSkill">
							<input type="hidden" name="skillId" value="@skill.Id" />
							<button type="submit" class="btn btn-success btn-sm">Approve</button>
						</form>
						<button type="button" class="btn btn-warning btn-sm"
										data-skill-id="@skill.Id"
										data-skill-name="@skill.Name"
										data-skill-desc="@skill.Description"
										data-skill-tags="@string.Join(", ", skill.Tags)"
										data-skill-categories="@string.Join(",", skill.Categories)"
										onclick="openEditModal(this)">
							Edit &amp; Approve
						</button>
						<button type="button" class="btn btn-outline-secondary btn-sm"
										data-skill-id="@skill.Id"
										onclick="openDuplicateModal(this)">
							Mark Duplicate
						</button>
						<form method="post" asp-page-handler="RejectSkill">
							<input type="hidden" name="skillId" value="@skill.Id" />
							<button type="submit" class="btn btn-danger btn-sm"
											onclick="return confirm('Permanently reject and delete this skill?')">
								Reject
							</button>
						</form>
					</div>
				</div>
				<div class="card-body">
					<p class="card-text">@skill.Description</p>
					@if (skill.Tags.Any())
					{
						<div class="mt-2">
							@foreach (var tag in skill.Tags)
							{
								<span class="badge bg-secondary me-1">@tag</span>
							}
						</div>
					}
				</div>
			</div>
		}
	</div>
}

<!-- Edit & Approve Modal -->
<div class="modal fade" id="editApproveModal" tabindex="-1">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<div id="modalCloseButton" class="modal-header">
				<h5 class="modal-title">Edit &amp; Approve Skill</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<form method="post" asp-page-handler="ApproveWithEdits">
				<div class="modal-body">
					<input type="hidden" asp-for="EditSkillId" id="editSkillIdInput" />
					<div class="mb-3">
						<label asp-for="EditName" class="form-label">Name</label>
						<input asp-for="EditName" id="editNameInput" class="form-control" />
					</div>
					<div class="mb-3">
						<label asp-for="EditDescription" class="form-label">Description</label>
						<textarea asp-for="EditDescription" id="editDescInput"
											class="form-control" rows="4"></textarea>
					</div>
					<div class="mb-3">
						<label asp-for="EditTags" class="form-label">Tags</label>
						<input asp-for="EditTags" id="editTagsInput" class="form-control"
									 placeholder="comma-separated tags" />
						<div class="form-text">Comma-separated list of tags.</div>
					</div>
					@if (Model.Categories.Any())
					{
						<div class="mb-3">
							<label class="form-label">Categories</label>
							<div class="d-flex flex-wrap gap-2" id="editCategoriesContainer">
								@foreach (var cat in Model.Categories)
								{
									<div class="form-check">
										<input class="form-check-input" type="checkbox"
													 name="EditCategoryIds" value="@cat.Id"
													 data-cat-name="@cat.Name" id="editCat_@cat.Id" />
										<label class="form-check-label" for="editCat_@cat.Id">@cat.Name</label>
									</div>
								}
							</div>
						</div>
					}
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
					<button type="submit" class="btn btn-warning">Approve with Edits</button>
				</div>
			</form>
		</div>
	</div>
</div>

<!-- Mark Duplicate Modal -->
<div class="modal fade" id="duplicateModal" tabindex="-1">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Mark as Duplicate</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<form method="post" asp-page-handler="MarkDuplicate">
				<div class="modal-body">
					<input type="hidden" asp-for="DuplicateSkillId" id="duplicateSkillIdInput" />
					<p class="text-muted small">
						This skill will be deleted and any users who have it will be reassigned
						to the selected existing skill.
					</p>
					<div class="mb-3">
						<label asp-for="ExistingSkillId" class="form-label">
							Existing Approved Skill
						</label>
						@if (Model.ApprovedSkills.Any())
						{
							<select asp-for="ExistingSkillId" class="form-select">
								<option value="0">Select a skill…</option>
								@foreach (var s in Model.ApprovedSkills.OrderBy(s => s.Name))
								{
									<option value="@s.Id">@s.Name</option>
								}
							</select>
						}
						else
						{
							<p class="text-muted">No approved skills exist yet.</p>
						}
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
					<button type="submit" class="btn btn-outline-secondary">Confirm Duplicate</button>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		function openEditModal(btn) {
				document.getElementById('editSkillIdInput').value = btn.dataset.skillId;
				document.getElementById('editNameInput').value = btn.dataset.skillName;
				document.getElementById('editDescInput').value = btn.dataset.skillDesc;
				document.getElementById('editTagsInput').value = btn.dataset.skillTags;

				const currentCategories = btn.dataset.skillCategories
						? btn.dataset.skillCategories.split(',').map(s => s.trim())
						: [];
				document.querySelectorAll('#editCategoriesContainer input[type="checkbox"]').forEach(cb => {
						cb.checked = currentCategories.includes(cb.dataset.catName);
				});

				bootstrap.Modal.getOrCreateInstance(document.getElementById('editApproveModal')).show();
		}

		function openDuplicateModal(btn) {
				document.getElementById('duplicateSkillIdInput').value = btn.dataset.skillId;
				bootstrap.Modal.getOrCreateInstance(document.getElementById('duplicateModal')).show();
		}
	</script>
}
